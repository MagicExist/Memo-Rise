# MemoRise backend — required environment variables (no real values here).
# Copy to `.env` for local dev; set real values in Railway for production.

ENVIRONMENT=development

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=

# Anthropic (used by U4; model is configurable, default claude-sonnet-5)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
AI_INPUT_MAX_CHARS=5000
AI_MAX_CARDS=20

# CORS
FRONTEND_ORIGIN=http://localhost:3000
