# MemoRise frontend — public env vars (no secrets). Set real values in Vercel for production.

# The FastAPI backend base URL (Pattern A: frontend calls the backend only).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase public values (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
